{
  "name": "aicode-thin-client",
  "displayName": "aicode Local Agent",
  "description": "VS Code client with managed local server, editor chat, and diff preview for aicode",
  "version": "0.1.7",
  "publisher": "aicode-local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aicode-sidebar",
          "title": "aicode",
          "icon": "media/aicode.svg"
        }
      ]
    },
    "views": {
      "aicode-sidebar": [
        {
          "id": "aicodeSidebarView",
          "name": "Quick Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "aicodeSidebarView",
        "contents": "Use **Open Chat Panel** to work in the full UX, or run quick actions from this sidebar."
      }
    ],
    "commands": [
      {
        "command": "aicode.ask",
        "title": "aicode: Ask"
      },
      {
        "command": "aicode.openPanel",
        "title": "aicode: Open Chat Panel"
      },
      {
        "command": "aicode.status",
        "title": "aicode: Check API Status"
      },
      {
        "command": "aicode.restartServer",
        "title": "aicode: Restart Local Server"
      },
      {
        "command": "aicode.startServer",
        "title": "aicode: Start Local Server"
      },
      {
        "command": "aicode.stopServer",
        "title": "aicode: Stop Local Server"
      },
      {
        "command": "aicode.startOllama",
        "title": "aicode: Start Ollama Task"
      },
      {
        "command": "aicode.stopOllama",
        "title": "aicode: Stop Ollama Task"
      },
      {
        "command": "aicode.runWorkspaceTask",
        "title": "aicode: Run VS Code Task"
      },
      {
        "command": "aicode.showActionLog",
        "title": "aicode: Show Action Log"
      },
      {
        "command": "aicode.editCurrentFile",
        "title": "aicode: Edit Current File"
      },
      {
        "command": "aicode.editSelection",
        "title": "aicode: Edit Selection"
      },
      {
        "command": "aicode.inlineChat",
        "title": "aicode: Inline Chat"
      },
      {
        "command": "aicode.applyInlineSuggestion",
        "title": "aicode: Apply Inline Suggestion"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aicode.editSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "navigation@10"
        },
        {
          "command": "aicode.inlineChat",
          "when": "editorTextFocus",
          "group": "navigation@11"
        }
      ],
      "editor/title": [
        {
          "command": "aicode.editCurrentFile",
          "when": "editorTextFocus",
          "group": "navigation@10"
        },
        {
          "command": "aicode.inlineChat",
          "when": "editorTextFocus",
          "group": "navigation@11"
        }
      ]
    },
    "configuration": {
      "title": "aicode",
      "properties": {
        "aicode.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8005",
          "description": "Base URL of local aicode server"
        },
        "aicode.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start and health-check the local aicode server when VS Code activates the extension for this workspace."
        },
        "aicode.autoStartOllama": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start Ollama with 'ollama serve' when the extension needs model access and Ollama is not reachable."
        },
        "aicode.ollamaPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path (or workspace-relative path) to the Ollama executable. Defaults to /opt/homebrew/bin/ollama on macOS, otherwise 'ollama' from PATH."
        },
        "aicode.showManagedProcessesInTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Launch extension-managed aicode server and Ollama inside named VS Code terminals so live logs stay visible."
        },
        "aicode.preferWorkspaceTasks": {
          "type": "boolean",
          "default": true,
          "description": "Prefer running workspace VS Code tasks like run:aicode-server and run:ollama-serve before falling back to extension-managed processes."
        },
        "aicode.stopServerOnDeactivate": {
          "type": "boolean",
          "default": true,
          "description": "Stop extension-managed local aicode server when the workspace closes or the extension deactivates."
        },
        "aicode.serverRoot": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Python app root that contains src/server.py. Defaults to the parent of this extension."
        },
        "aicode.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Optional workspace root passed to the local aicode server as WORKSPACE_ROOT. Defaults to serverRoot."
        },
        "aicode.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python interpreter used to launch the local aicode server. Defaults to .venv/bin/python when present."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:clean": "node scripts/compile_clean.js",
    "watch": "tsc -watch -p ./",
    "test:smoke": "npm run compile:clean && node --test smoke/**/*.test.cjs",
    "verify:vsix": "node scripts/verify_vsix.js",
    "package:release": "node scripts/package_release.js",
    "package:vsix": "npm run package:release",
    "install:vsix": "node scripts/install_vsix.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3"
  }
}
